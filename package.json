{
  "name": "dongjun-codedex",
  "version": "0.1.0",
  "private": true,
  "description": "포켓몬 도감 컨셉의 BOJ 코딩테스트 학습 사이트 (하네스 엔지니어링 적용)",
  "scripts": {
    "data:boj": "node scripts/index-boj.mjs",
    "data:pokedex": "node scripts/build-pokedex.mjs",
    "data:taxonomy": "node scripts/build-pokemon-taxonomy.mjs",
    "data:map": "node scripts/build-monster-map.mjs",
    "data:all": "npm run data:boj && npm run data:pokedex && npm run data:taxonomy && npm run data:map",
    "dev": "next dev",
    "build": "npm run data:all && next build",
    "start": "next start",
    "lint": "next lint",
    "judge:dev": "python judge/server.py",
    "harness:test": "python -m unittest discover -s harness/tests -p \"test_*.py\"",
    "judge:audit": "node scripts/audit-judge-cases.mjs",
    "judge:coverage": "node scripts/audit-judge-coverage.mjs",
    "judge:lang-audit": "node scripts/audit-language-support.mjs",
    "judge:quality": "python scripts/audit-override-quality.py",
    "judge:docker-check": "python scripts/check-docker-runner.py",
    "judge:verify-overrides": "python scripts/verify-judge-overrides.py",
    "problems:expansion-audit": "node scripts/audit-problem-expansion.mjs",
    "problems:expansion-solvedac": "node scripts/enrich-expansion-solvedac.mjs",
    "problems:external-audit": "node scripts/audit-external-solutions.mjs",
    "problems:batch-01": "node scripts/plan-expansion-batch-01.mjs",
    "problems:first-5": "node scripts/plan-expansion-first-5.mjs",
    "problems:import-first-5": "node scripts/import-expansion-first-5.mjs",
    "problems:batch-02": "node scripts/plan-expansion-batch-02.mjs",
    "problems:import-batch-02-ready": "node scripts/import-expansion-batch-02-ready.mjs",
    "problems:import-manual-strings": "node scripts/import-expansion-manual-strings.mjs",
    "ops:check-env": "node --env-file=.env scripts/check-env.mjs",
    "ops:check-env:example": "node --env-file=.env.example scripts/check-env.mjs",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=18.18"
  }
}
