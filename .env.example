JUDGE_URL=http://127.0.0.1:5050/judge
JUDGE_RUN_URL=http://127.0.0.1:5050/run
JUDGE_PORT=5050
JUDGE_USE_DOCKER=1
CODERUNNER_IMAGE=dongjun-coderunner:latest
JUDGE_MAX_CONCURRENT_JOBS=3
JUDGE_JOB_ACQUIRE_TIMEOUT_S=2.0
JUDGE_ENABLE_GENERIC_FUZZ=0

# Request safety limits
JUDGE_MAX_CODE_BYTES=65536
JUDGE_MAX_STDIN_BYTES=65536
JUDGE_MAX_BODY_BYTES=262144
JUDGE_MAX_OUTPUT_BYTES=67108864

# In-memory per-IP limit for /api/judge.
# For multi-server production, replace this with Redis or another shared store.
JUDGE_RATE_LIMIT_WINDOW_MS=60000
JUDGE_RATE_LIMIT_MAX=20

# Optional social login.
# Set these after creating Kakao/Naver developer applications.
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://127.0.0.1:3000/api/auth/kakao/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://127.0.0.1:3000/api/auth/naver/callback
